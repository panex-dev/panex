<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v4 source for the Panex MSI installer.

  Build with:
    wix build panex.wxs -o panex.msi \
      -d Version=0.1.0 \
      -d BinaryPath=path\to\panex.exe \
      -arch x64

  The installer:
    - Installs panex.exe to %ProgramFiles%\Panex\
    - Adds the install directory to the system PATH
    - Registers an uninstaller in Add/Remove Programs
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Panex"
    Manufacturer="Panex"
    Version="$(Version)"
    UpgradeCode="8A3F4C2E-1B5D-4E7A-9C0F-6D2A8B4E1F3C"
    Scope="perMachine">

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of Panex is already installed." />

    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="Panex">
        <Component Id="PanexBinary" Guid="7E2C4A1B-3D5F-4890-AB12-9F6E8D0C7B3A">
          <File Id="PanexExe" Source="$(BinaryPath)" KeyPath="yes" />
        </Component>

        <Component Id="PanexPath" Guid="B1C2D3E4-F5A6-4789-8012-3456789ABCDE">
          <Environment
            Id="PATH"
            Name="PATH"
            Value="[INSTALLFOLDER]"
            Permanent="no"
            Part="last"
            Action="set"
            System="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="Panex" Level="1">
      <ComponentRef Id="PanexBinary" />
      <ComponentRef Id="PanexPath" />
    </Feature>

  </Package>
</Wix>
