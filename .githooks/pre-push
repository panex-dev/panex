#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Capture stdin (ref info from git) before any script consumes it
push_info="$(cat)"

./scripts/pr-ensure-rebased.sh

# Ensure every push includes a build-log entry
echo "$push_info" | ./scripts/ensure-build-log.sh
